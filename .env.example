# Copie para .env e preencha. NUNCA commite o .env.

# Telegram (BotFather → token; getUpdates → chat_id)
TELEGRAM_BOT_TOKEN=123456:ABC-coloque-seu-token-aqui
TELEGRAM_CHAT_ID=000000000

# Google Sheets (service account JSON em UMA linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Segredo do scheduler (/run-check?secret=...)
CRON_SECRET=troque-por-um-segredo-longo

# Fuso horário
APP_TIMEZONE=America/Sao_Paulo

# Janela de busca nos dias de sorteio (hora local BRT) e limite de tentativas.
# Opcionais — estes são os padrões.
BUSCA_HORA_INICIO=20
BUSCA_HORA_FIM=22
BUSCA_MAX_TENTATIVAS=10
